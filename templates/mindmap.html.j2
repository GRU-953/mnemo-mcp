<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Mnemo — {{ project_name }}</title>
{% raw %}
<style>
  :root{--bg:#0f1115;--panel:#171a21;--fg:#e8eaed;--muted:#9aa4b2;--accent:#6ea8fe;--border:#262b36;}
  *{box-sizing:border-box;}
  html,body{margin:0;height:100%;background:var(--bg);color:var(--fg);
    font:14px/1.5 -apple-system,BlinkMacSystemFont,Segoe UI,Roboto,Helvetica,sans-serif;}
  #app{display:flex;flex-direction:column;height:100vh;}
  header{padding:10px 14px;border-bottom:1px solid var(--border);display:flex;gap:12px;
    align-items:center;flex-wrap:wrap;}
  header h1{font-size:15px;margin:0;font-weight:600;white-space:nowrap;}
  header .stats{color:var(--muted);font-size:12px;white-space:nowrap;}
  header input[type=search]{background:var(--panel);border:1px solid var(--border);color:var(--fg);
    padding:6px 10px;border-radius:8px;width:200px;outline:none;}
  header input[type=search]:focus{border-color:var(--accent);}
  .legend{display:flex;gap:6px;flex-wrap:wrap;margin-left:auto;}
  .chip{display:inline-flex;align-items:center;gap:5px;padding:3px 9px;border:1px solid var(--border);
    border-radius:20px;font-size:11px;cursor:pointer;user-select:none;background:var(--panel);}
  .chip.off{opacity:.35;text-decoration:line-through;}
  .dot{width:9px;height:9px;border-radius:50%;display:inline-block;}
  .main{flex:1;position:relative;min-height:0;}
  #cy{position:absolute;inset:0;}
  #panel{position:absolute;top:0;right:0;width:350px;max-width:88vw;height:100%;background:var(--panel);
    border-left:1px solid var(--border);padding:18px;overflow:auto;transform:translateX(106%);
    transition:transform .2s ease;box-shadow:-8px 0 24px rgba(0,0,0,.3);}
  #panel.open{transform:none;}
  #panel h2{font-size:17px;margin:.3em 0;}
  #panel .type{display:inline-block;font-size:11px;padding:2px 9px;border-radius:20px;color:#0b0d11;font-weight:600;}
  #panel .sec{margin-top:15px;}
  #panel .sec h3{font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);margin:0 0 6px;}
  #panel ul{margin:0;padding-left:18px;}
  #panel li{margin-bottom:5px;}
  #panel .close{float:right;cursor:pointer;color:var(--muted);font-size:16px;}
  #panel .close:hover{color:var(--fg);}
  .btn{background:var(--panel);border:1px solid var(--border);color:var(--fg);padding:6px 11px;
    border-radius:8px;cursor:pointer;}
  .btn:hover{border-color:var(--accent);}
  footer{padding:6px 14px;border-top:1px solid var(--border);color:var(--muted);font-size:11px;}
  .hint{position:absolute;bottom:14px;left:14px;color:var(--muted);font-size:11px;pointer-events:none;
    background:rgba(15,17,21,.7);padding:4px 8px;border-radius:6px;}
</style>
{% endraw %}
</head>
<body>
<div id="app">
  <header>
    <h1>🧠 {{ project_name }}</h1>
    <span class="stats">{{ stats_line }}</span>
    <input id="search" type="search" placeholder="Search entities…" autocomplete="off">
    <button class="btn" id="fit">Fit</button>
    <div class="legend" id="legend"></div>
  </header>
  <div class="main">
    <div id="cy"></div>
    <div class="hint">Click a node to explore · scroll to zoom · drag to pan</div>
    <aside id="panel"></aside>
  </div>
  <footer>Generated {{ generated }} · Mnemo — local, token-free graph memory</footer>
</div>
{{ cytoscape_tag }}
<script>window.MNEMO = {{ data_json }};</script>
{% raw %}
<script>
(function(){
  const M = window.MNEMO, colors = M.typeColors || {};
  const colorFor = t => colors[t] || colors._default || '#999';
  function esc(s){return (s==null?'':String(s)).replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));}
  const nodeEls = M.elements.filter(e=>e.data && !e.data.source);
  const maxDeg = Math.max(1, ...nodeEls.map(e=>e.data.degree||0));
  const cy = cytoscape({
    container: document.getElementById('cy'),
    elements: M.elements,
    wheelSensitivity: 0.25,
    style: [
      { selector:'node', style:{
        'background-color': ele=>colorFor(ele.data('type')),
        'label':'data(label)','color':'#dfe3e8','font-size':9,
        'text-valign':'bottom','text-halign':'center','text-margin-y':3,
        'width': ele=>14+30*Math.sqrt((ele.data('degree')||0)/maxDeg),
        'height': ele=>14+30*Math.sqrt((ele.data('degree')||0)/maxDeg),
        'text-wrap':'ellipsis','text-max-width':100,'min-zoomed-font-size':6,'border-width':0 } },
      { selector:'edge', style:{
        'width':1,'line-color':'#39414f','target-arrow-color':'#39414f',
        'target-arrow-shape':'triangle','arrow-scale':.7,'curve-style':'bezier',
        'label':'data(label)','font-size':7,'color':'#7c8694','text-opacity':0,'text-rotation':'autorotate'} },
      { selector:'.faded', style:{'opacity':0.10} },
      { selector:'node.hi', style:{'border-width':3,'border-color':'#fff'} },
      { selector:'edge.hi', style:{'line-color':'#6ea8fe','target-arrow-color':'#6ea8fe','width':2,'text-opacity':1} }
    ],
    layout:{name:'cose',animate:false,nodeRepulsion:9000,idealEdgeLength:95,padding:40,
            componentSpacing:120,nodeOverlap:12,randomize:true}
  });
  // legend + type toggles
  const types=[...new Set(nodeEls.map(e=>e.data.type))].sort();
  const legend=document.getElementById('legend'), off=new Set();
  types.forEach(t=>{
    const c=document.createElement('span'); c.className='chip';
    c.innerHTML='<span class="dot" style="background:'+colorFor(t)+'"></span>'+t;
    c.onclick=()=>{ off.has(t)?(off.delete(t),c.classList.remove('off')):(off.add(t),c.classList.add('off'));
      cy.nodes().forEach(n=>n.style('display',off.has(n.data('type'))?'none':'element')); };
    legend.appendChild(c);
  });
  document.getElementById('fit').onclick=()=>cy.fit(null,40);
  const panel=document.getElementById('panel');
  function clearHi(){cy.elements().removeClass('faded hi');}
  function showNode(n){
    const d=n.data();
    let h='<span class="close" id="pc">✕</span>';
    h+='<span class="type" style="background:'+colorFor(d.type)+'">'+esc(d.type)+'</span>';
    h+='<h2>'+esc(d.label)+'</h2>';
    if(d.description) h+='<p>'+esc(d.description)+'</p>';
    const facts=d.facts||[];
    if(facts.length) h+='<div class="sec"><h3>Facts</h3><ul>'+facts.map(f=>'<li>'+esc(f)+'</li>').join('')+'</ul></div>';
    const neigh=[...new Set(n.neighborhood('node').map(x=>x.data('label')))].slice(0,18);
    if(neigh.length) h+='<div class="sec"><h3>Connected ('+n.degree()+')</h3><ul>'+neigh.map(x=>'<li>'+esc(x)+'</li>').join('')+'</ul></div>';
    const src=d.sources||[];
    if(src.length) h+='<div class="sec"><h3>Sources</h3><ul>'+src.map(s=>'<li>'+esc(s)+'</li>').join('')+'</ul></div>';
    panel.innerHTML=h; panel.classList.add('open');
    document.getElementById('pc').onclick=()=>{panel.classList.remove('open');clearHi();};
  }
  cy.on('tap','node',e=>{const n=e.target;clearHi();cy.elements().addClass('faded');
    const nb=n.closedNeighborhood();nb.removeClass('faded');n.addClass('hi');nb.edges().addClass('hi');showNode(n);});
  cy.on('tap',e=>{if(e.target===cy){clearHi();panel.classList.remove('open');}});
  const search=document.getElementById('search');
  search.oninput=()=>{const q=search.value.trim().toLowerCase();clearHi();if(!q)return;
    const m=cy.nodes().filter(n=>(n.data('label')||'').toLowerCase().includes(q));
    cy.elements().addClass('faded');m.removeClass('faded').addClass('hi');m.connectedEdges().removeClass('faded');
    if(m.length)cy.fit(m,80);};
})();
</script>
{% endraw %}
</body>
</html>
